---
import BaseLayout from "../layouts/BaseLayout.astro";
import SubmissionForm from "../components/SubmissionForm.tsx";
import AuthBanner from "../components/SubmitAuthBanner.tsx";
---

<BaseLayout title="Submit a Skill" description="Submit a medical AI skill or plugin for physician review and listing.">
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Submit a Skill</h1>
    <p class="mt-2 text-slate-600 dark:text-slate-400">
      Contribute to the medical AI community. All submissions are reviewed by physician maintainers.
    </p>

    <!-- Auth status banner -->
    <AuthBanner client:load />

    <!-- Two-path layout -->
    <div class="mt-10 grid grid-cols-1 gap-8 lg:grid-cols-2">
      <!-- Left: Technical (GitHub) -->
      <div class="rounded-xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-900">
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-slate-100 dark:bg-slate-800">
            <svg class="h-5 w-5 text-slate-700 dark:text-slate-300" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </div>
          <div>
            <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Technical Submission</h2>
            <p class="text-sm text-slate-500">For GitHub users</p>
          </div>
        </div>

        <div class="mt-6 space-y-4 text-sm text-slate-600 dark:text-slate-400">
          <p>If you are comfortable with GitHub, you can submit directly:</p>

          <div class="space-y-3">
            <div class="flex gap-3">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary-50 text-xs font-bold text-primary dark:bg-primary-900/30 dark:text-primary-light">1</span>
              <span>Fork the repository and create a new branch</span>
            </div>
            <div class="flex gap-3">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary-50 text-xs font-bold text-primary dark:bg-primary-900/30 dark:text-primary-light">2</span>
              <span>Add a YAML file to <code class="rounded bg-slate-100 px-1.5 py-0.5 text-xs dark:bg-slate-800">content/skills/</code></span>
            </div>
            <div class="flex gap-3">
              <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary-50 text-xs font-bold text-primary dark:bg-primary-900/30 dark:text-primary-light">3</span>
              <span>Open a pull request for physician review</span>
            </div>
          </div>

          <p class="text-xs text-slate-500">Or use our issue template for a guided submission.</p>
        </div>

        <div class="mt-6 flex flex-col gap-3">
          <a
            href="https://github.com/gitjfmd/open-medical-skills/issues/new?template=skill-submission.md"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-medium text-white transition-colors hover:bg-slate-800 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            Open Issue Template
          </a>
          <a
            href="https://github.com/gitjfmd/open-medical-skills"
            target="_blank"
            rel="noopener noreferrer"
            class="text-center text-sm text-slate-500 hover:text-primary dark:text-slate-400 dark:hover:text-primary-light"
          >
            View Repository
          </a>
        </div>
      </div>

      <!-- Right: Non-Technical (Web Form) -->
      <div class="rounded-xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-900">
        <div class="flex items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-50 dark:bg-primary-900/30">
            <svg class="h-5 w-5 text-primary dark:text-primary-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <div>
            <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Web Form Submission</h2>
            <p class="text-sm text-slate-500">No GitHub account needed</p>
          </div>
        </div>

        <div class="mt-6">
          <SubmissionForm client:load />
        </div>
      </div>
    </div>

    <!-- Submission Guidelines -->
    <section class="mt-12">
      <h2 class="text-lg font-semibold text-slate-900 dark:text-white">What Makes a Good Skill?</h2>
      <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { title: "Clear Purpose", desc: "Solves a specific clinical need or automates a healthcare workflow." },
          { title: "Evidence-Based", desc: "Grounded in clinical guidelines, medical literature, or established protocols." },
          { title: "Safety Aware", desc: "Includes appropriate disclaimers and does not make unsupported claims." },
          { title: "Well Documented", desc: "Clear README with usage examples, limitations, and requirements." },
          { title: "Open Source", desc: "Published under an open source license with accessible source code." },
          { title: "Actively Maintained", desc: "Repository shows recent activity and responds to issues." },
        ].map((item) => (
          <div class="rounded-lg border border-slate-200 bg-slate-50 p-4 dark:border-slate-800 dark:bg-slate-900/50">
            <h3 class="text-sm font-medium text-slate-900 dark:text-white">{item.title}</h3>
            <p class="mt-1 text-xs text-slate-600 dark:text-slate-400">{item.desc}</p>
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
