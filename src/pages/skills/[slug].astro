---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import InstallCommands from "../../components/InstallCommands.astro";
import AgentActions from "../../components/AgentActions.astro";
import SkillFileViewer from "../../components/SkillFileViewer.astro";
import SkillSocialBar from "../../components/SkillSocialBar.astro";
import { CATEGORY_LABELS, CATEGORY_STYLES, EVIDENCE_STYLES, SAFETY_STYLES } from "../../lib/categories";

export async function getStaticPaths() {
  const skills = await getCollection("skills");
  return skills.map((skill) => ({
    params: { slug: skill.id },
    props: { skill },
  }));
}

const { skill } = Astro.props;
const { data } = skill;

const catStyle = CATEGORY_STYLES[data.category as keyof typeof CATEGORY_STYLES];
const catLabel = CATEGORY_LABELS[data.category as keyof typeof CATEGORY_LABELS] ?? data.category;
const evidenceStyle = EVIDENCE_STYLES[data.evidence_level] ?? EVIDENCE_STYLES.moderate;
const safetyStyle = SAFETY_STYLES[data.safety_classification] ?? SAFETY_STYLES.safe;
---

<BaseLayout title={data.display_name} description={data.description}>
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Back link -->
    <a
      href="/skills"
      class="inline-flex items-center gap-1 text-sm text-slate-500 hover:text-primary dark:text-slate-400 dark:hover:text-primary-light"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path d="M15 19l-7-7 7-7" />
      </svg>
      Back to Skills
    </a>

    <!-- Header -->
    <div class="mt-6">
      <div class="flex flex-wrap items-center gap-3">
        <span
          class:list={[
            "inline-flex items-center rounded-full border px-3 py-1 text-sm font-medium",
            catStyle?.bg,
            catStyle?.text,
            catStyle?.border,
          ]}
        >
          {catLabel}
        </span>

        <span class:list={["inline-flex items-center rounded-full px-3 py-1 text-sm font-medium", safetyStyle.bg, safetyStyle.text]}>
          {safetyStyle.label}
        </span>

        <span class="flex items-center gap-1.5 text-sm text-slate-500" title={evidenceStyle.label}>
          <span class:list={["inline-block h-2.5 w-2.5 rounded-full", evidenceStyle.dot]}></span>
          {evidenceStyle.label}
        </span>

        {data.verified && (
          <span class="inline-flex items-center gap-1 text-sm font-medium text-primary dark:text-primary-light">
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
              <path
                fill-rule="evenodd"
                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z"
                clip-rule="evenodd"
              />
            </svg>
            Verified
          </span>
        )}
      </div>

      <h1 class="mt-4 text-3xl font-bold text-slate-900 dark:text-white">{data.display_name}</h1>
      <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">by {data.author}</p>

      <!-- Social Bar -->
      <SkillSocialBar skillSlug={skill.id} skillName={data.display_name} />
    </div>

    <!-- Description -->
    <div class="mt-8">
      <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Description</h2>
      <p class="mt-2 text-slate-600 leading-relaxed dark:text-slate-400">{data.description}</p>
    </div>

    <!-- Agent Actions (Quick Install) -->
    <AgentActions skillName={data.name} displayName={data.display_name} repository={data.repository} />

    <!-- Install Commands -->
    <div class="mt-8">
      <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Installation</h2>
      <div class="mt-3">
        <InstallCommands install={data.install} />
      </div>
    </div>

    <!-- Skill Files (script + README) -->
    {(data.script_content || data.skill_md) && (
      <SkillFileViewer
        scriptContent={data.script_content}
        scriptLanguage={data.script_language}
        skillMd={data.skill_md}
      />
    )}

    <!-- Metadata grid -->
    <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2">
      {data.version && (
        <div class="rounded-lg border border-slate-200 bg-slate-50 p-4 dark:border-slate-800 dark:bg-slate-900">
          <p class="text-xs font-medium uppercase tracking-wider text-slate-500">Version</p>
          <p class="mt-1 text-sm font-medium text-slate-900 dark:text-white">{data.version}</p>
        </div>
      )}

      {data.license && (
        <div class="rounded-lg border border-slate-200 bg-slate-50 p-4 dark:border-slate-800 dark:bg-slate-900">
          <p class="text-xs font-medium uppercase tracking-wider text-slate-500">License</p>
          <p class="mt-1 text-sm font-medium text-slate-900 dark:text-white">{data.license}</p>
        </div>
      )}

      <div class="rounded-lg border border-slate-200 bg-slate-50 p-4 dark:border-slate-800 dark:bg-slate-900">
        <p class="text-xs font-medium uppercase tracking-wider text-slate-500">Reviewer</p>
        <p class="mt-1 text-sm font-medium text-slate-900 dark:text-white">{data.reviewer}</p>
      </div>

      <div class="rounded-lg border border-slate-200 bg-slate-50 p-4 dark:border-slate-800 dark:bg-slate-900">
        <p class="text-xs font-medium uppercase tracking-wider text-slate-500">Date Added</p>
        <p class="mt-1 text-sm font-medium text-slate-900 dark:text-white">{data.date_added}</p>
      </div>
    </div>

    <!-- Specialties -->
    {data.specialty.length > 0 && (
      <div class="mt-6">
        <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Specialties</h2>
        <div class="mt-2 flex flex-wrap gap-2">
          {data.specialty.map((s: string) => (
            <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-sm text-slate-600 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-400">
              {s.replace(/-/g, " ").replace(/\b\w/g, (c: string) => c.toUpperCase())}
            </span>
          ))}
        </div>
      </div>
    )}

    <!-- Tags -->
    {data.tags.length > 0 && (
      <div class="mt-6">
        <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Tags</h2>
        <div class="mt-2 flex flex-wrap gap-2">
          {data.tags.map((tag: string) => (
            <span class="rounded-md bg-slate-100 px-2.5 py-1 text-sm text-slate-600 dark:bg-slate-800 dark:text-slate-400">
              {tag}
            </span>
          ))}
        </div>
      </div>
    )}

    <!-- Repository + Report -->
    <div class="mt-8 flex flex-wrap items-center gap-4 border-t border-slate-200 pt-6 dark:border-slate-800">
      <a
        href={data.repository}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-lg bg-slate-900 px-4 py-2.5 text-sm font-medium text-white transition-colors hover:bg-slate-800 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-200"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        View on GitHub
      </a>
      <a
        href={`${data.repository}/issues/new?title=Issue%20with%20${encodeURIComponent(data.display_name)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-300"
      >
        Report an issue
      </a>
    </div>
  </div>
</BaseLayout>
