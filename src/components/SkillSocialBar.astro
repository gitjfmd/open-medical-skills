---
interface Props {
  skillSlug: string;
  skillName: string;
}

const { skillSlug, skillName } = Astro.props;
---

<div
  class="mt-6 flex flex-wrap items-center gap-2"
  data-social-bar
  data-skill-slug={skillSlug}
  data-skill-name={skillName}
>
  <!-- Star Button -->
  <button
    data-star-btn
    class="inline-flex items-center gap-1.5 rounded-md border border-slate-200 bg-white px-3 py-1.5 text-sm font-medium text-slate-600 transition-colors hover:border-primary hover:text-primary dark:border-slate-700 dark:bg-slate-800 dark:text-slate-400 dark:hover:border-primary-light dark:hover:text-primary-light"
  >
    <!-- Empty star (default) -->
    <svg data-star-icon-empty class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
    </svg>
    <!-- Filled star (starred state) -->
    <svg data-star-icon-filled class="hidden h-4 w-4 text-primary dark:text-primary-light" viewBox="0 0 24 24" fill="currentColor">
      <path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
    </svg>
    <span data-star-label>Star</span>
    <span class="ml-0.5 rounded-md bg-slate-100 px-1.5 py-0.5 text-xs font-medium tabular-nums text-slate-500 dark:bg-slate-700 dark:text-slate-400" data-star-count>0</span>
  </button>

  <!-- Fork Button -->
  <a
    href="https://github.com/gitjfmd/oms-site/fork"
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-1.5 rounded-md border border-slate-200 bg-white px-3 py-1.5 text-sm font-medium text-slate-600 transition-colors hover:border-primary hover:text-primary dark:border-slate-700 dark:bg-slate-800 dark:text-slate-400 dark:hover:border-primary-light dark:hover:text-primary-light"
  >
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="18" r="3" />
      <circle cx="6" cy="6" r="3" />
      <circle cx="18" cy="6" r="3" />
      <path d="M18 9v2c0 .6-.4 1-1 1H7c-.6 0-1-.4-1-1V9" />
      <path d="M12 12v3" />
    </svg>
    Fork
  </a>

  <!-- Share Button (with dropdown) -->
  <div class="relative" data-share-wrapper>
    <button
      data-share-btn
      class="inline-flex items-center gap-1.5 rounded-md border border-slate-200 bg-white px-3 py-1.5 text-sm font-medium text-slate-600 transition-colors hover:border-primary hover:text-primary dark:border-slate-700 dark:bg-slate-800 dark:text-slate-400 dark:hover:border-primary-light dark:hover:text-primary-light"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8" />
        <polyline points="16 6 12 2 8 6" />
        <line x1="12" y1="2" x2="12" y2="15" />
      </svg>
      Share
    </button>

    <!-- Share dropdown -->
    <div
      data-share-dropdown
      class="absolute right-0 z-20 mt-1 hidden w-52 origin-top-right rounded-lg border border-slate-200 bg-white py-1 shadow-lg dark:border-slate-700 dark:bg-slate-800"
    >
      <button
        data-copy-link-btn
        class="flex w-full items-center gap-2.5 px-3.5 py-2 text-left text-sm text-slate-600 transition-colors hover:bg-slate-50 dark:text-slate-300 dark:hover:bg-slate-700"
      >
        <svg class="h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71" />
          <path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71" />
        </svg>
        <span data-copy-link-label>Copy link</span>
      </button>

      <a
        data-share-x
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-600 transition-colors hover:bg-slate-50 dark:text-slate-300 dark:hover:bg-slate-700"
      >
        <svg class="h-4 w-4 shrink-0 text-slate-400" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
        </svg>
        Share on X
      </a>

      <a
        data-share-linkedin
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2.5 px-3.5 py-2 text-sm text-slate-600 transition-colors hover:bg-slate-50 dark:text-slate-300 dark:hover:bg-slate-700"
      >
        <svg class="h-4 w-4 shrink-0 text-slate-400" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
        </svg>
        Share on LinkedIn
      </a>
    </div>
  </div>
</div>

<script>
  const COPY_FEEDBACK_DELAY_MS = 2000;

  function initializeSocialBar() {
    document.querySelectorAll<HTMLDivElement>("[data-social-bar]").forEach((bar) => {
      const slug = bar.dataset.skillSlug ?? "";
      const skillName = bar.dataset.skillName ?? "";
      const storageKey = `oms-star-${slug}`;

      // --- Star functionality ---
      const starBtn = bar.querySelector<HTMLButtonElement>("[data-star-btn]");
      const iconEmpty = bar.querySelector<SVGElement>("[data-star-icon-empty]");
      const iconFilled = bar.querySelector<SVGElement>("[data-star-icon-filled]");
      const starLabel = bar.querySelector<HTMLSpanElement>("[data-star-label]");
      const starCountEl = bar.querySelector<HTMLSpanElement>("[data-star-count]");

      // Generate a deterministic base count from the skill slug (10-500 range)
      const MIN_STAR_COUNT = 10;
      const STAR_COUNT_RANGE = 491;

      function computeHashCode(str: string): number {
        let hash = 0;
        for (let i = 0; i < str.length; i++) {
          const char = str.charCodeAt(i);
          hash = ((hash << 5) - hash) + char;
          hash |= 0;
        }
        return Math.abs(hash);
      }
      const baseCount = MIN_STAR_COUNT + (computeHashCode(slug) % STAR_COUNT_RANGE);

      // Check localStorage for starred state
      const isStarred = localStorage.getItem(storageKey) === "1";
      const currentCount = isStarred ? baseCount + 1 : baseCount;

      function renderStar(starred: boolean, count: number) {
        if (!iconEmpty || !iconFilled || !starLabel || !starCountEl || !starBtn) return;
        if (starred) {
          iconEmpty.classList.add("hidden");
          iconFilled.classList.remove("hidden");
          starLabel.textContent = "Starred";
          starBtn.classList.add("border-primary", "text-primary", "dark:border-primary-light", "dark:text-primary-light");
          starBtn.classList.remove("border-slate-200", "text-slate-600", "dark:border-slate-700", "dark:text-slate-400");
        } else {
          iconEmpty.classList.remove("hidden");
          iconFilled.classList.add("hidden");
          starLabel.textContent = "Star";
          starBtn.classList.remove("border-primary", "text-primary", "dark:border-primary-light", "dark:text-primary-light");
          starBtn.classList.add("border-slate-200", "text-slate-600", "dark:border-slate-700", "dark:text-slate-400");
        }
        starCountEl.textContent = String(count);
      }

      renderStar(isStarred, currentCount);

      let starred = isStarred;
      starBtn?.addEventListener("click", () => {
        starred = !starred;
        if (starred) {
          localStorage.setItem(storageKey, "1");
        } else {
          localStorage.removeItem(storageKey);
        }
        const count = starred ? baseCount + 1 : baseCount;
        renderStar(starred, count);
      });

      // --- Share dropdown ---
      const shareBtn = bar.querySelector<HTMLButtonElement>("[data-share-btn]");
      const shareDropdown = bar.querySelector<HTMLDivElement>("[data-share-dropdown]");

      shareBtn?.addEventListener("click", (e) => {
        e.stopPropagation();
        shareDropdown?.classList.toggle("hidden");
      });

      // Close on outside click
      document.addEventListener("click", (e) => {
        if (shareDropdown && !shareDropdown.contains(e.target as Node) && e.target !== shareBtn) {
          shareDropdown.classList.add("hidden");
        }
      });

      // Copy link button
      const copyLinkBtn = bar.querySelector<HTMLButtonElement>("[data-copy-link-btn]");
      const copyLinkLabel = bar.querySelector<HTMLSpanElement>("[data-copy-link-label]");

      copyLinkBtn?.addEventListener("click", async () => {
        await navigator.clipboard.writeText(window.location.href);
        if (copyLinkLabel) {
          copyLinkLabel.textContent = "Copied!";
          setTimeout(() => {
            copyLinkLabel.textContent = "Copy link";
          }, COPY_FEEDBACK_DELAY_MS);
        }
        shareDropdown?.classList.add("hidden");
      });

      // Set share URLs
      const pageUrl = encodeURIComponent(window.location.href);
      const shareText = encodeURIComponent(`Check out "${skillName}" on Open Medical Skills`);

      const shareX = bar.querySelector<HTMLAnchorElement>("[data-share-x]");
      if (shareX) {
        shareX.href = `https://x.com/intent/tweet?text=${shareText}&url=${pageUrl}`;
      }

      const shareLinkedin = bar.querySelector<HTMLAnchorElement>("[data-share-linkedin]");
      if (shareLinkedin) {
        shareLinkedin.href = `https://www.linkedin.com/sharing/share-offsite/?url=${pageUrl}`;
      }
    });
  }

  // Initialize when DOM is ready
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initializeSocialBar);
  } else {
    initializeSocialBar();
  }
</script>
