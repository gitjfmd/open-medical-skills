# Open Medical Skills — Environment Variables
# Copy to .env and fill in your values
#
# Secrets managed via: ./scripts/secrets-sync.sh
# Manifest: ./scripts/secrets-manifest.json

# === GitHub OAuth ===
GITHUB_PAT=your_github_pat_here
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here

# === Cloudflare ===
CF_API_TOKEN=your_cf_api_token_here
CF_ACCOUNT_ID=your_cf_account_id_here

# === Database ===
DB_USER=your_db_user_here
DB_PASSWORD=your_db_password_here
DB_NAME=your_db_name_here
DB_HOST=localhost
DB_PORT=5432

# === OAuth ===
OAUTH_REDIRECT_URI=http://localhost:4321/auth/callback

# === API Keys (optional) ===
OPENFDA_API_KEY=
NCBI_API_KEY=

# === Site Configuration ===
ALLOWED_ORIGIN=http://localhost:4321
API_BASE_URL=http://localhost:8787

# === LLM Provider (for Skill Creator) ===
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3
